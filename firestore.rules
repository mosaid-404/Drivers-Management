rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. & 2. Drivers Validation
    function isValidDriver(data) {
      return data.keys().hasAll(['userId', 'code', 'name', 'route', 'factory', 'mobile', 'status'])
        && data.userId == request.auth.uid
        && data.code is string && data.code.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.route is string && data.route.size() <= 128
        && data.factory is string && data.factory.size() <= 128
        && (data.get('carType', '') is string && data.get('carType', '').size() <= 128)
        && data.mobile is string && data.mobile.size() <= 32
        && data.status in ['active', 'retired']
        && (data.get('notes', []) is list && data.get('notes', []).size() <= 100)
        && (data.get('updatedAt', request.time) == request.time || data.get('updatedAt', null) == existing().get('updatedAt', null));
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn() && (
        resource == null || 
        !('userId' in resource.data) || 
        resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() && isValidId(driverId) 
        && isValidDriver(incoming())
        && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(driverId) 
        && (!('userId' in existing()) || existing().userId == request.auth.uid)
        && (
          // Allow all known fields in update
          (incoming().diff(existing()).affectedKeys().hasOnly(['userId', 'code', 'name', 'route', 'factory', 'carType', 'mobile', 'status', 'notes', 'updatedAt', 'createdAt']))
          && (incoming().get('userId', request.auth.uid) == request.auth.uid)
          && (incoming().get('createdAt', request.time) == existing().get('createdAt', request.time))
          && isValidDriver(incoming())
        );
      allow delete: if isSignedIn() && (
        resource == null || 
        !('userId' in resource.data) || 
        resource.data.userId == request.auth.uid
      );
    }

    // Job Records Validation
    function isValidJobRecord(data) {
      return data.keys().hasAll(['userId', 'driverId', 'month', 'items', 'deductions', 'totalWork', 'totalDeductions', 'netPay', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.driverId is string && data.driverId.size() <= 128
        && data.month is string && data.month.matches('^[0-9]{4}-[0-9]{2}$')
        && data.items is list && data.items.size() <= 100
        && data.deductions is list && data.deductions.size() <= 100
        && data.totalWork is number
        && data.totalDeductions is number
        && data.netPay is number
        && (data.get('isPaid', false) is bool)
        && data.updatedAt == request.time;
    }

    match /jobRecords/{recordId} {
      allow read: if isSignedIn() && (
        resource == null || 
        !('userId' in resource.data) || 
        resource.data.userId == request.auth.uid
      );
      allow write: if isSignedIn() && isValidId(recordId) && isValidJobRecord(incoming()) && (
        !exists(/databases/$(database)/documents/jobRecords/$(recordId)) || 
        !('userId' in get(/databases/$(database)/documents/jobRecords/$(recordId)).data) ||
        get(/databases/$(database)/documents/jobRecords/$(recordId)).data.userId == request.auth.uid
      );
    }
  }
}
